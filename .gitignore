# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
env/

# Cache directories (LLM responses, git clones)
.cache/

# Pipeline output directories (generated, not source).
# Promote a curated subset to examples/ if you want to ship it.
output/
output_*/
results/

# Research/case-study artefacts (kept on disk, but not in source control —
# they are large, evolve per-run, and rebuild from the pipeline).
audits/
case_studies/
slides/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Azure AD token cache
*.bin
cloudgpt-apim-token-cache.*

# Debug logs
*.log
*_log.txt
*_run.log

# Claude Code / agent temp files
tmpclaude-*
agent_results.json
.claude/

# Test / coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Generated deck (rebuild with `python scripts/build_pptx.py`)
docs/overview.pptx

# Scratch / working files at the repo root (e.g. _dump_one.py, _scratch.md).
# Anchored with `/` so they do NOT match legitimate underscored package
# directories like `bench_cleanser/_internal/`.
/_*.py
/_*/
/_*.json
/_*.md
